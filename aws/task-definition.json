{
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "family": "learn-jenkins-taks-definition",
  "containerDefinitions": [
    {
      "name": "learnjenkinsapp",
      "image": "886058822965.dkr.ecr.us-east-1.amazonaws.com/learn-jenkins-app:#APP_VERSION#",
      "portMappings": [
        {
          "name" : "nginx-80-tcp",
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true
    }
  ],
  "volumes": [],
  "networkMode": "awsvpc",
  "memory": "512",
  "cpu": "256",
  "executionRoleArn": "arn:aws:iam::886058822965:role/ecsTaskExecutionRole"
}